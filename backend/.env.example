# -----------------------------------------------------------------------
# Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# -----------------------------------------------------------------------

# AWS Credentials (used as fallback if not provided via request headers)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# S3 Bucket for diagram uploads
S3_BUCKET=nova-diagram-uploads

# Amazon Bedrock Model ID
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Application Settings
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Security: Secret key for session signing (generate a strong random string)
APP_SECRET_KEY=change-me-to-a-random-secret-key
